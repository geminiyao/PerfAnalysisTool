{
  "name": "perf-dashboard",
  "version": "1.0.0",
  "description": "Unity Profiler Performance Analysis Web Dashboard",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "db:migrate": "tsx server/db/migrate.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.0.0",
    "antd": "^5.22.0",
    "better-sqlite3": "^11.6.0",
    "dayjs": "^1.11.13",
    "drizzle-orm": "^0.36.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "fastify": "^5.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.0",
    "react-router-dom": "^6.28.0",
    "remark-gfm": "^4.0.0",
    "uuid": "^11.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.28.0",
    "less": "^4.2.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.11"
  }
}
