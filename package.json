{
  "name": "perf-analysis-tool",
  "version": "1.0.0",
  "description": "Performance Analysis Tool - CPU, Memory, Power, FPS",
  "main": "./out/main/index.js",
  "author": "PerfAnalysisTool",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:win": "electron-vite build && electron-builder --win --config",
    "build:mac": "electron-vite build && electron-builder --mac --config",
    "build:linux": "electron-vite build && electron-builder --linux --config",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.perfanalysis.tool",
    "productName": "PerfAnalysisTool",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "icon": "resources/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "shortcutName": "PerfAnalysisTool",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@electron-toolkit/utils": "^4.0.0",
    "@tencent-ai/agent-sdk": "file:./vendor/agent-sdk",
    "antd": "^5.22.0",
    "echarts": "^5.5.1",
    "echarts-for-react": "^3.0.2",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^28.3.3",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "less": "^4.2.0",
    "typescript": "~5.6.0",
    "vite": "^5.4.11"
  }
}
