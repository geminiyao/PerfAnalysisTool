{
  "targetFps": 30,
  "gameProcess": "com.tencent.aoeyz",
  "jank": {
    "jankMultiplier": 2,
    "bigJankMultiplier": 3
  },
  "mainThread": {
    "name": "UnityMain"
  },
  "renderThread": {
    "name": "UnityGfxRenderS"
  },
  "filter": {
    "minSliceDurMs": 0.1
  },
  "blacklist": [
    "Semaphore.WaitForSignal",
    "WaitForJobGroupID"
  ],
  "jobWorker": {
    "namePatterns": ["Worker Thread", "Job.Worker", "Job Worker"],
    "threadIdPatterns": ["Thread-"],
    "highUtilizationThreshold": 60,
    "lowUtilizationThreshold": 10
  },
  "gpu": {
    "utilizationHighThreshold": 80,
    "frequencyTrackNames": ["gpu_frequency", "gpufreq", "GPU Frequency"],
    "utilizationTrackNames": ["gpu_utilization", "GPU Utilization", "gpu_busy", "GPU Busy"]
  },
  "timeSegment": {
    "segmentCount": 3,
    "thermalDegradationThreshold": 0.85,
    "burstSpikeConcentration": 0.6,
    "warmupThreshold": 1.15,
    "sustainedSlowFrames": 5,
    "sustainedSlowMultiplier": 1.5
  },
  "playerLoopPhases": {
    "rendering": ["PostLateUpdate.FinishFrameRendering"],
    "logic_update": ["Update.ScriptRunBehaviourUpdate", "BehaviourUpdate"],
    "logic_late": ["PreLateUpdate.ScriptRunBehaviourLateUpdate", "LateBehaviourUpdate"],
    "ecs": ["SimulationSystemGroup", "InitializationSystemGroup", "PresentationSystemGroup", "Default World"],
    "ui": ["PostLateUpdate.PlayerUpdateCanvases"],
    "wait": ["PostLateUpdate.PlayerSendFrameComplete", "WaitForJobGroupID", "Gfx.WaitForPresent"],
    "luaIdentifiers": ["CS:AOE", "LuaMgr", "CS:"]
  }
}
